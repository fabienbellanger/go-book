# Binaires compilés
*.exe
*.exe~
*.dll
*.so
*.dylib
/code/**/bin/
/projets/**/bin/
/tools/**/bin/

# Site HTML généré (régénéré à la demande par tools/site, jamais commité)
/public/

# Sorties de test, couverture et profils
*.test
*.out
*.prof
*.pprof
coverage.*
*.trace

# Profil PGO de démonstration (généré par `go run . profile` au ch. 39)
/code/**/default.pgo

# Artefacts d'outils Go
/code/**/__debug_bin*
go.work
go.work.sum

# Brouillons de vérification (modules jetables hors livre)
/scratchpad/

# Système / éditeurs
.DS_Store
.idea/
.vscode/
*.swp
